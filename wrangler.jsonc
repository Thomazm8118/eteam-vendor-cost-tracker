{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eteam-vendor-cost-tracker",
  "main": "src/index.js",
  "compatibility_date": "2026-05-06",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  }
}
